{
  "name": "icora",
  "version": "0.3.1",
  "main": "./dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://icora.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devBash24/icora-package"
  },
  "bin": {
    "iconium": "dist/index.js"
  },
  "scripts": {
    "start": "node ./dist/index.js",
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "node --import tsx --test test/**/*.test.ts",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run pack:dry-run",
    "pack:dry-run": "npm pack --dry-run",
    "dev": "tsx watch src/index.ts",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "icora",
    "icora-cli",
    "icora-icons",
    "icora-web",
    "icora-web-cli",
    "icons"
  ],
  "author": "Bash John",
  "license": "ISC",
  "description": "Iconium CLI",
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^13.1.0",
    "inquirer": "^12.3.2"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.13.14",
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  },
  "bugs": {
    "url": "https://github.com/devBash24/icora-package/issues"
  }
}
